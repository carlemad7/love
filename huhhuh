<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>I LOVE YOU</title>

<style>

body{
margin:0;
font-family:Arial;
height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:linear-gradient(135deg,#FEFAE0,#FAEDCD);
overflow:hidden;
}

.container{
background:white;
padding:40px;
border-radius:20px;
box-shadow:0 10px 30px rgba(0,0,0,0.1);
text-align:center;
max-width:500px;
}

h1{
margin-bottom:20px;
}

button{
padding:12px 25px;
border:none;
margin:10px;
border-radius:12px;
font-size:16px;
cursor:pointer;
background:#D3FAC7;
transition:0.2s;
}

button:hover{
background:#B7E4C7;
}

#loveMeter{
width:100%;
}

.emoji{
position:absolute;
font-size:28px;
opacity:0.7;
animation:float 15s linear infinite;
}

@keyframes float{
0%{transform:translateY(100vh)}
100%{transform:translateY(-10vh)}
}

.heart{
position:absolute;
font-size:30px;
animation:float 10s linear infinite;
}

</style>

</head>

<body>

<!-- Omar Khairat music -->
<iframe 
width="0"
height="0"
scrolling="no"
frameborder="no"
allow="autoplay"
src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/copilotbassem/omar-khairat-the-case-of-am&auto_play=true">
</iframe>

<div class="container" id="main">

<h1 id="question">Do you like me?</h1>

<button onclick="yes1()">Yes</button>
<button id="noBtn" onclick="secret()">No</button>

</div>

<script>

const emojis=["🍣","🏎️","❤️","🍪"]

function createFloatingEmojis(){

for(let i=0;i<25;i++){

let e=document.createElement("div")
e.className="emoji"
e.innerText=emojis[Math.floor(Math.random()*emojis.length)]

e.style.left=Math.random()*100+"%"
e.style.animationDuration=10+Math.random()*10+"s"

document.body.appendChild(e)

}

}

createFloatingEmojis()

const noBtn=document.getElementById("noBtn")

noBtn.addEventListener("mouseover",()=>{

noBtn.style.position="absolute"
noBtn.style.left=Math.random()*80+"%"
noBtn.style.top=Math.random()*80+"%"

})

function secret(){

alert("I don't like you, I love you ❤️")

}

function yes1(){

document.getElementById("main").innerHTML=`

<h1>How much do you love me?</h1>

<input type="range" min="0" max="5000" value="100" id="loveMeter">

<p id="percent">100%</p>

<button onclick="next()">Next ❤️</button>

`

let slider=document.getElementById("loveMeter")
let percent=document.getElementById("percent")

slider.oninput=()=>{

percent.innerText=slider.value+"%"

}

}

function next(){

document.getElementById("main").innerHTML=`

<h1>You are mine and mine alone and you will never ever ever be shared</h1>

<button onclick="agree()">Agree</button>

<button id="runBtn">Disagree</button>

`

let runBtn=document.getElementById("runBtn")

runBtn.addEventListener("mouseover",()=>{

runBtn.style.position="absolute"
runBtn.style.left=Math.random()*80+"%"
runBtn.style.top=Math.random()*80+"%"

})

}

function agree(){

document.getElementById("main").innerHTML=`

<h1>You are crazyyyyyy ❤️</h1>

<p>
Hey kouki i know what we’re going through isn’t easy and that this is a a rough time but i wanted to tell you how proud i am of youu.

You are actually the strongest person i ever met and your faith is even stronger.

I want you to know that I will always be here for you and never leave your side.

Everytime I say I love you more, I don't mean more than you love me.

I mean I love you more than the bad days ahead of us,
more than any fight,
more than any distance,
more than any obstacle,
and more than the odds stacked against me.

I love you more than anything.
</p>

`

celebrate()

}

function celebrate(){

for(let i=0;i<40;i++){

let heart=document.createElement("div")

heart.className="heart"
heart.innerText="❤️"

heart.style.left=Math.random()*100+"%"
heart.style.animationDuration=5+Math.random()*5+"s"

document.body.appendChild(heart)

}

}

</script>

</body>
</html>
